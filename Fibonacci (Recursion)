#include <stdio.h>

int fibonacci(int n)
{
    if (n <= 1)
        return n;

    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main()
{
    int num;

    printf("Give value of n: ");
    scanf("%d", &num);

    if (num < 0)
    {
        printf("Wrong input\n");
        return 0;
    }

    printf("Result = %d\n", fibonacci(num));

    return 0;
}
