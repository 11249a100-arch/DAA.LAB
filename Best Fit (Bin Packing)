#include <stdio.h>

void bestFit(int arr[], int n, int cap)
{
    int space[n];
    int usedBins = 0;

    for (int i = 0; i < n; i++)
        space[i] = cap;

    for (int i = 0; i < n; i++)
    {
        int index = -1;
        int min = cap + 1;

        for (int j = 0; j < usedBins; j++)
        {
            if (space[j] >= arr[i] && (space[j] - arr[i]) < min)
            {
                index = j;
                min = space[j] - arr[i];
            }
        }

        if (index != -1)
        {
            space[index] -= arr[i];
            printf("Placed item %d in Bin %d\n", i + 1, index + 1);
        }
        else
        {
            space[usedBins] -= arr[i];
            printf("Placed item %d in Bin %d\n", i + 1, usedBins + 1);
            usedBins++;
        }
    }

    printf("Total bins = %d\n", usedBins);
}

int main()
{
    int n, cap;
    printf("Enter item count: ");
    scanf("%d", &n);

    printf("Enter capacity: ");
    scanf("%d", &cap);

    int arr[n];

    for (int i = 0; i < n; i++)
    {
        printf("Item %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    bestFit(arr, n, cap);
    return 0;
}
