#include <stdio.h>

void applyFirstFit(int arr[], int n, int cap)
{
    int space[n];
    int bins = 0;

    for (int i = 0; i < n; i++)
        space[i] = cap;

    for (int i = 0; i < n; i++)
    {
        int done = 0;

        for (int j = 0; j < bins; j++)
        {
            if (space[j] >= arr[i])
            {
                space[j] -= arr[i];
                printf("Item %d -> Bin %d\n", i + 1, j + 1);
                done = 1;
                break;
            }
        }

        if (!done)
        {
            space[bins] -= arr[i];
            printf("Item %d -> Bin %d\n", i + 1, bins + 1);
            bins++;
        }
    }

    printf("Bins used: %d\n", bins);
}

int main()
{
    int n, cap;

    printf("Items count: ");
    scanf("%d", &n);

    printf("Capacity: ");
    scanf("%d", &cap);

    int arr[n];

    for (int i = 0; i < n; i++)
    {
        printf("Value %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    applyFirstFit(arr, n, cap);

    return 0;
}
