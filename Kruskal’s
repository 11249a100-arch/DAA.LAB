#include <stdio.h>

#define V 5
#define E 6

int parent[V];

int find(int x)
{
    while (parent[x] != x)
        x = parent[x];
    return x;
}

void unite(int a, int b)
{
    parent[find(a)] = find(b);
}

void sort(int edge[E][3])
{
    for (int i = 0; i < E - 1; i++)
        for (int j = 0; j < E - i - 1; j++)
            if (edge[j][2] > edge[j + 1][2])
                for (int k = 0; k < 3; k++)
                {
                    int t = edge[j][k];
                    edge[j][k] = edge[j + 1][k];
                    edge[j + 1][k] = t;
                }
}

int main()
{
    int edge[E][3] = {
        {0,1,2},{0,2,3},{1,2,5},
        {1,3,3},{2,4,4},{3,4,2}
    };

    sort(edge);

    for (int i = 0; i < V; i++)
        parent[i] = i;

    int cost = 0;

    printf("Edges selected:\n");

    for (int i = 0; i < E; i++)
    {
        if (find(edge[i][0]) != find(edge[i][1]))
        {
            printf("%d-%d (%d)\n", edge[i][0], edge[i][1], edge[i][2]);
            unite(edge[i][0], edge[i][1]);
            cost += edge[i][2];
        }
    }

    printf("Total = %d\n", cost);
    return 0;
}
