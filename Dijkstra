#include <stdio.h>

#define V 5
#define INF 999999

int minDist(int dist[], int visit[])
{
    int min = INF, idx = -1;

    for (int i = 0; i < V; i++)
        if (!visit[i] && dist[i] <= min)
        {
            min = dist[i];
            idx = i;
        }

    return idx;
}

void dijkstra(int g[V][V])
{
    int dist[V], visit[V];

    for (int i = 0; i < V; i++)
    {
        dist[i] = INF;
        visit[i] = 0;
    }

    dist[0] = 0;

    for (int i = 0; i < V; i++)
    {
        int u = minDist(dist, visit);
        visit[u] = 1;

        for (int j = 0; j < V; j++)
        {
            if (g[u][j] && !visit[j] && dist[j] > dist[u] + g[u][j])
                dist[j] = dist[u] + g[u][j];
        }
    }

    printf("Shortest distances:\n");
    for (int i = 0; i < V; i++)
        printf("%d -> %d\n", i, dist[i]);
}

int main()
{
    int g[V][V] = {
        {0,10,0,30,100},
        {10,0,50,0,0},
        {0,50,0,20,10},
        {30,0,20,0,60},
        {100,0,10,60,0}
    };

    dijkstra(g);
    return 0;
}
